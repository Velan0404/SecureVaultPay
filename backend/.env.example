# Copy this file to .env and fill in real values. Never commit .env.

DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Server ---
PORT=5000
NODE_ENV=development

# --- JWT ---
JWT_ACCESS_SECRET="generate-a-long-random-secret"
JWT_REFRESH_SECRET="generate-a-different-long-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY_DAYS=30

# --- PIN policy ---
PIN_LOCKOUT_ATTEMPTS=5

# --- OTP policy (Forgot Password) ---
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- Resend (OTP email delivery) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="SecureVault Pay <onboarding@resend.dev>"

# --- Firebase Admin (push notifications) ---
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Twilio Verify (Transaction Authentication OTP — Main Wallet transfers only) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  ANDROID
  IOS
}

enum PurposeWalletStatus {
  ACTIVE
  ARCHIVED
}

// Deliberately broader than what Phase 4 uses (only WALLET_CREATED,
// WALLET_UPDATED, WALLET_DELETED, DEMO_LOAD, and MAIN_TO_PURPOSE are written
// today) so future payment/scheduling modules can reuse this table without a
// breaking migration. PURPOSE_TO_MAIN, PURPOSE_PAYMENT, REFUND, and
// ADJUSTMENT are reserved, not implemented in this phase.
enum WalletTransactionType {
  WALLET_CREATED
  WALLET_UPDATED
  WALLET_DELETED
  DEMO_LOAD
  MAIN_TO_PURPOSE
  PURPOSE_TO_MAIN
  PURPOSE_PAYMENT
  REFUND
  ADJUSTMENT
  // Phase 7 — Personal QR (User -> User, into the receiver's Main Wallet).
  PERSONAL_PAYMENT_SENT
  PERSONAL_PAYMENT_RECEIVED
}

enum WalletTransactionStatus {
  SUCCESS
  FAILED
}

// State machine for Transaction Authentication (fingerprint-then-OTP,
// required before any Main Wallet -> Purpose Wallet transfer, and — as of
// the Merchant Payment module — before any Purpose Wallet -> Merchant
// payment too). No OTP code is ever stored here — only status/timestamps,
// since Twilio Verify owns generation and validation entirely.
enum TransactionAuthStatus {
  PENDING_FINGERPRINT
  FINGERPRINT_CONFIRMED
  OTP_SENT
  OTP_VERIFIED
  COMPLETED
  EXPIRED
  CANCELLED
}

enum MerchantCategory {
  GROCERY
  FOOD
  FUEL
  SHOPPING
  ENTERTAINMENT
  HEALTHCARE
  EDUCATION
  UTILITY
  TRAVEL
  OTHER
}

enum MerchantStatus {
  ACTIVE
  INACTIVE
}

enum MerchantPaymentStatus {
  SUCCESS
  FAILED
}

enum MerchantQrStatus {
  ACTIVE
  USED
  EXPIRED
}

// Phase 7 (Scheduled Payments) — a category/icon label only, orthogonal to
// whether the schedule's destination is a Merchant or another User.
enum ScheduledPaymentType {
  RENT
  ELECTRICITY
  WATER
  INTERNET
  MOBILE_RECHARGE
  SUBSCRIPTION
  EMI
  INSURANCE
  SAVINGS
  CUSTOM
}

enum ScheduledPaymentFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
  CUSTOM // interval in days, stored in ScheduledPayment.customIntervalDays
}

enum ScheduledPaymentStatus {
  ACTIVE
  PAUSED
  COMPLETED // reached endDate naturally
  CANCELLED // user stopped it
}

enum ScheduledPaymentExecutionStatus {
  SUCCESS
  FAILED
}

model User {
  id                String             @id @default(uuid())
  fullName          String
  email             String             @unique
  passwordHash      String
  pinHash           String?
  biometricEnabled  Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Required before Transaction Authentication (Twilio OTP delivery) can be
  // used — set via the transaction-auth module, not the registration flow.
  phoneNumber String?

  // Permanent personal-payment identity code (Phase 7) — e.g. "SVP-7K9X2QRT".
  // Lazily generated on first "My QR" request, like MainWallet/PaymentPin,
  // rather than backfilled for existing users at migration time.
  secureVaultId String? @unique

  devices                  Device[]
  refreshTokens            RefreshToken[]
  auditLogs                AuditLog[]
  passwordResetOtps        PasswordResetOtp[]
  mainWallet               MainWallet?
  walletTransactions       WalletTransaction[]
  transactionAuthSessions  TransactionAuthSession[]
  merchantPayments         MerchantPayment[]
  paymentPin               PaymentPin?
  personalPaymentsSent     PersonalPayment[] @relation("PersonalPaymentsSent")
  personalPaymentsReceived PersonalPayment[] @relation("PersonalPaymentsReceived")
  scheduledPayments         ScheduledPayment[]
  scheduledPaymentsReceived ScheduledPayment[] @relation("ScheduledPaymentsReceived")
}

// A dedicated, separate credential from User.pinHash (the App PIN, which
// only unlocks the app). The Payment PIN authorizes money movement — every
// merchant payment is verified against this hash server-side, never against
// a client-cached copy. `userId @unique` enforces "only one Payment PIN per
// user, created once."
model PaymentPin {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  pinHash   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TransactionAuthSession {
  id                     String                @id @default(uuid())
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id])
  deviceId               String
  purposeWalletId        String
  // null = a Main Wallet -> Purpose Wallet transfer session (original,
  // unchanged behavior). Set = a Purpose Wallet -> Merchant payment session.
  // A single session can only ever authorize one or the other.
  merchantId             String?
  merchant               Merchant?             @relation(fields: [merchantId], references: [id])
  amount                 Decimal               @db.Decimal(14, 2)
  status                 TransactionAuthStatus @default(PENDING_FINGERPRINT)
  otpAttempts            Int                   @default(0)
  fingerprintConfirmedAt DateTime?
  otpSentAt              DateTime?
  otpVerifiedAt          DateTime?
  completedAt            DateTime?
  expiresAt              DateTime
  createdAt              DateTime              @default(now())
}

model Merchant {
  id               String           @id @default(uuid())
  merchantName     String
  merchantCategory MerchantCategory
  merchantCode     String           @unique
  merchantLogo     String?
  status           MerchantStatus   @default(ACTIVE)
  createdAt        DateTime         @default(now())

  payments                MerchantPayment[]
  transactionAuthSessions TransactionAuthSession[]
  qrCodes                 MerchantQrCode[]
  scheduledPayments       ScheduledPayment[]
}

// A dynamic, single-use, time-boxed QR token (Phase 6) — the demo stand-in
// for a real merchant terminal, which would normally regenerate its
// displayed QR periodically for exactly this reason. Scanning only reads
// this record (see qr.service.js's validate()); paying atomically
// compare-and-swaps status ACTIVE -> USED, which is what makes a second
// scan/payment of the same QR (a replay) impossible to complete twice.
model MerchantQrCode {
  id         String           @id @default(uuid())
  merchantId String
  merchant   Merchant         @relation(fields: [merchantId], references: [id])
  status     MerchantQrStatus @default(ACTIVE)
  expiresAt  DateTime
  usedAt     DateTime?
  // Nullable, no formal FK — same pattern as MerchantPayment.transactionAuthSessionId
  // (Phase 5): an informational link to the payment this QR produced,
  // without touching the MerchantPayment model at all.
  merchantPaymentId String?
  createdAt         DateTime @default(now())
}

model MerchantPayment {
  id                       String                @id @default(uuid())
  userId                   String
  user                     User                  @relation(fields: [userId], references: [id])
  purposeWalletId          String
  purposeWallet            PurposeWallet         @relation(fields: [purposeWalletId], references: [id])
  merchantId               String
  merchant                 Merchant              @relation(fields: [merchantId], references: [id])
  amount                   Decimal               @db.Decimal(14, 2)
  status                   MerchantPaymentStatus @default(SUCCESS)
  transactionAuthSessionId String?
  createdAt                DateTime              @default(now())
}

// Phase 7 — Personal QR: User -> User, always landing in the receiver's Main
// Wallet. Reuses MerchantPaymentStatus (identical SUCCESS/FAILED shape)
// rather than declaring a duplicate enum.
model PersonalPayment {
  id                    String                @id @default(uuid())
  senderId              String
  sender                User                  @relation("PersonalPaymentsSent", fields: [senderId], references: [id])
  receiverId            String
  receiver              User                  @relation("PersonalPaymentsReceived", fields: [receiverId], references: [id])
  senderPurposeWalletId String
  senderPurposeWallet   PurposeWallet         @relation(fields: [senderPurposeWalletId], references: [id])
  amount                Decimal               @db.Decimal(14, 2)
  note                  String?
  status                MerchantPaymentStatus @default(SUCCESS)
  createdAt             DateTime              @default(now())
}

model MainWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purposeWallets PurposeWallet[]
  transfers      WalletTransfer[]
  transactions   WalletTransaction[]
}

model PurposeWallet {
  id            String              @id @default(uuid())
  mainWalletId  String
  mainWallet    MainWallet          @relation(fields: [mainWalletId], references: [id])
  name          String
  icon          String
  color         String
  purpose       String?
  balance       Decimal             @default(0) @db.Decimal(14, 2)
  spendingLimit Decimal?            @db.Decimal(14, 2)
  status        PurposeWalletStatus @default(ACTIVE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  transfers        WalletTransfer[]
  transactions     WalletTransaction[]
  merchantPayments MerchantPayment[]
  personalPayments PersonalPayment[]
  scheduledPayments ScheduledPayment[]
}

model WalletTransfer {
  id              String        @id @default(uuid())
  mainWalletId    String
  mainWallet      MainWallet    @relation(fields: [mainWalletId], references: [id])
  purposeWalletId String
  purposeWallet   PurposeWallet @relation(fields: [purposeWalletId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
}

model WalletTransaction {
  id              String                  @id @default(uuid())
  userId          String
  user            User                    @relation(fields: [userId], references: [id])
  mainWalletId    String?
  mainWallet      MainWallet?             @relation(fields: [mainWalletId], references: [id])
  purposeWalletId String?
  purposeWallet   PurposeWallet?          @relation(fields: [purposeWalletId], references: [id])
  type            WalletTransactionType
  amount          Decimal                 @db.Decimal(14, 2)
  source          String?
  destination     String?
  description     String?
  status          WalletTransactionStatus @default(SUCCESS)
  createdAt       DateTime                @default(now())
}

model Device {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  deviceId      String
  deviceName    String?
  platform      Platform
  fcmToken      String?
  lastLogin     DateTime       @default(now())
  createdAt     DateTime       @default(now())

  refreshTokens RefreshToken[]

  @@unique([userId, deviceId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  deviceId   String
  device     Device    @relation(fields: [deviceId], references: [id])
  tokenHash  String    @unique
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model PasswordResetOtp {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  otpHash    String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

// Phase 7 — Scheduled Payments & Automation. Executed by scheduler.service.js
// (node-cron), which calls the existing, unmodified merchantService.pay()/
// personalPaymentService.pay() directly — no Payment PIN at execution time,
// only at creation/editing (see paymentPin.middleware.js on the create/edit
// routes). Exactly one of merchantId/receiverUserId is set, and never changes
// after creation (editing a schedule cannot change who it pays).
model ScheduledPayment {
  id                 String                    @id @default(uuid())
  userId             String
  user               User                      @relation(fields: [userId], references: [id])
  title              String
  paymentType        ScheduledPaymentType      @default(CUSTOM)
  amount             Decimal                   @db.Decimal(14, 2)
  frequency          ScheduledPaymentFrequency
  customIntervalDays Int?
  purposeWalletId    String
  purposeWallet      PurposeWallet             @relation(fields: [purposeWalletId], references: [id])
  merchantId         String?
  merchant           Merchant?                 @relation(fields: [merchantId], references: [id])
  receiverUserId     String?
  receiverUser       User?                     @relation("ScheduledPaymentsReceived", fields: [receiverUserId], references: [id])
  note               String?
  startDate          DateTime
  nextExecution      DateTime
  lastExecution      DateTime?
  // Set to the nextExecution value the last "upcoming payment" reminder
  // covered — dedupes the reminder per cycle without a separate boolean,
  // since nextExecution always changes after each run.
  lastReminderFor    DateTime?
  endDate            DateTime?
  status             ScheduledPaymentStatus    @default(ACTIVE)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  executions ScheduledPaymentExecution[]
}

// One row per cron-tick attempt at a due ScheduledPayment — the audit trail
// an "Execution History" screen reads. paymentId is an informational link
// only (no FK), same pattern as MerchantQrCode.merchantPaymentId.
model ScheduledPaymentExecution {
  id                 String                          @id @default(uuid())
  scheduledPaymentId String
  scheduledPayment   ScheduledPayment                @relation(fields: [scheduledPaymentId], references: [id])
  scheduledFor       DateTime
  executedAt         DateTime                        @default(now())
  status             ScheduledPaymentExecutionStatus
  amount             Decimal                         @db.Decimal(14, 2)
  failureReason      String?
  paymentId          String?
}

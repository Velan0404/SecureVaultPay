// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Platform {
  ANDROID
  IOS
}

enum PurposeWalletStatus {
  ACTIVE
  ARCHIVED
}

// Deliberately broader than what Phase 4 uses (only WALLET_CREATED,
// WALLET_UPDATED, WALLET_DELETED, DEMO_LOAD, and MAIN_TO_PURPOSE are written
// today) so future payment/scheduling modules can reuse this table without a
// breaking migration. PURPOSE_TO_MAIN, PURPOSE_PAYMENT, REFUND, and
// ADJUSTMENT are reserved, not implemented in this phase.
enum WalletTransactionType {
  WALLET_CREATED
  WALLET_UPDATED
  WALLET_DELETED
  DEMO_LOAD
  MAIN_TO_PURPOSE
  PURPOSE_TO_MAIN
  PURPOSE_PAYMENT
  REFUND
  ADJUSTMENT
}

enum WalletTransactionStatus {
  SUCCESS
  FAILED
}

// State machine for Transaction Authentication (fingerprint-then-OTP,
// required before any Main Wallet -> Purpose Wallet transfer). No OTP code
// is ever stored here — only status/timestamps, since Twilio Verify owns
// generation and validation entirely.
enum TransactionAuthStatus {
  PENDING_FINGERPRINT
  FINGERPRINT_CONFIRMED
  OTP_SENT
  OTP_VERIFIED
  COMPLETED
  EXPIRED
  CANCELLED
}

model User {
  id                String             @id @default(uuid())
  fullName          String
  email             String             @unique
  passwordHash      String
  pinHash           String?
  biometricEnabled  Boolean            @default(false)
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Required before Transaction Authentication (Twilio OTP delivery) can be
  // used — set via the transaction-auth module, not the registration flow.
  phoneNumber String?

  devices                 Device[]
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  passwordResetOtps       PasswordResetOtp[]
  mainWallet              MainWallet?
  walletTransactions      WalletTransaction[]
  transactionAuthSessions TransactionAuthSession[]
}

model TransactionAuthSession {
  id                     String                @id @default(uuid())
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id])
  deviceId               String
  purposeWalletId        String
  amount                 Decimal               @db.Decimal(14, 2)
  status                 TransactionAuthStatus @default(PENDING_FINGERPRINT)
  otpAttempts            Int                   @default(0)
  fingerprintConfirmedAt DateTime?
  otpSentAt              DateTime?
  otpVerifiedAt          DateTime?
  completedAt            DateTime?
  expiresAt              DateTime
  createdAt              DateTime              @default(now())
}

model MainWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Decimal  @default(0) @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purposeWallets PurposeWallet[]
  transfers      WalletTransfer[]
  transactions   WalletTransaction[]
}

model PurposeWallet {
  id            String              @id @default(uuid())
  mainWalletId  String
  mainWallet    MainWallet          @relation(fields: [mainWalletId], references: [id])
  name          String
  icon          String
  color         String
  purpose       String?
  balance       Decimal             @default(0) @db.Decimal(14, 2)
  spendingLimit Decimal?            @db.Decimal(14, 2)
  status        PurposeWalletStatus @default(ACTIVE)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  transfers    WalletTransfer[]
  transactions WalletTransaction[]
}

model WalletTransfer {
  id              String        @id @default(uuid())
  mainWalletId    String
  mainWallet      MainWallet    @relation(fields: [mainWalletId], references: [id])
  purposeWalletId String
  purposeWallet   PurposeWallet @relation(fields: [purposeWalletId], references: [id])
  amount          Decimal       @db.Decimal(14, 2)
  createdAt       DateTime      @default(now())
}

model WalletTransaction {
  id              String                  @id @default(uuid())
  userId          String
  user            User                    @relation(fields: [userId], references: [id])
  mainWalletId    String?
  mainWallet      MainWallet?             @relation(fields: [mainWalletId], references: [id])
  purposeWalletId String?
  purposeWallet   PurposeWallet?          @relation(fields: [purposeWalletId], references: [id])
  type            WalletTransactionType
  amount          Decimal                 @db.Decimal(14, 2)
  source          String?
  destination     String?
  description     String?
  status          WalletTransactionStatus @default(SUCCESS)
  createdAt       DateTime                @default(now())
}

model Device {
  id            String         @id @default(uuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id])
  deviceId      String
  deviceName    String?
  platform      Platform
  fcmToken      String?
  lastLogin     DateTime       @default(now())
  createdAt     DateTime       @default(now())

  refreshTokens RefreshToken[]

  @@unique([userId, deviceId])
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  deviceId   String
  device     Device    @relation(fields: [deviceId], references: [id])
  tokenHash  String    @unique
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
}

model PasswordResetOtp {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  otpHash    String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}
